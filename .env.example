# =============================================================================
# Clip Central — Environment Variables
# Copy to .env and fill in values. All three services read from the root .env.
# =============================================================================

# --- Supabase (Clip Central project) ---
SUPABASE_URL=https://vesfjjekalfcvpevluxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard

# --- Discord Bot ---
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-id
DISCORD_GUILD_ID=your-guild-id
DISCORD_CAMPAIGN_CHANNEL_ID=your-default-campaign-channel-id
DISCORD_CLIENT_SECRET=your-oauth-client-secret

# --- Admin Dashboard (NextAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
ADMIN_DISCORD_IDS=your-discord-user-id

# --- Inter-service auth (min 16 chars each — "bot"/"worker" will NOT work) ---
BOT_INTERNAL_KEY=generate-a-long-random-string-at-least-16-chars
WORKER_API_KEY=generate-another-long-random-string-at-least-16-chars

# --- Service URLs (local dev defaults) ---
BOT_INTERNAL_URL=http://localhost:3001
# Railway: use references instead of a composite URL (leave BOT_INTERNAL_URL unset)
# DISCORD_BOT_PRIVATE_HOST=
# DISCORD_BOT_PRIVATE_PORT=
BOT_HTTP_PORT=3001
WORKER_URL=http://localhost:3002
# Railway: use references instead (leave WORKER_URL unset)
# VIDEOS_WORKER_PRIVATE_HOST=
# VIDEOS_WORKER_PRIVATE_PORT=
PORT=3002

# --- Redis (BullMQ for videos worker) ---
# Local:
REDIS_URL=redis://localhost:6379
# Railway worker (recommended — references to Redis service):
# REDIS_PRIVATE_HOST=
# REDIS_PASSWORD=
# REDISPORT=6379
# REDISUSER=default
# Local dev against remote Railway Redis:
# REDIS_PUBLIC_URL=redis://default:password@your-proxy.up.railway.app:12345

# --- Scrape Creators API (https://docs.scrapecreators.com) ---
SCRAPECREATORS_API_KEY=your-scrapecreators-api-key

# --- Worker tuning ---
REFRESH_INTERVAL_HOURS=6
REQUEST_DELAY_MS=200
QUEUE_POLL_INTERVAL_MS=3000
