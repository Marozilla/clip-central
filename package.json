{
  "name": "clip-central",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "build:libs": "pnpm --filter @clip-central/shared build && pnpm --filter @clip-central/db build && pnpm --filter @clip-central/platform-adapter build && pnpm --filter @clip-central/storage build",
    "build:admin": "pnpm run build:libs && pnpm --filter @clip-central/admin build",
    "build:bot": "pnpm run build:libs && pnpm --filter @clip-central/discord-bot build",
    "build:worker": "pnpm run build:libs && pnpm --filter @clip-central/videos-worker build",
    "dev": "pnpm -r --parallel dev",
    "dev:bot": "pnpm --filter @clip-central/discord-bot dev",
    "dev:worker": "pnpm --filter @clip-central/videos-worker dev",
    "dev:admin": "pnpm --filter @clip-central/admin dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0"
  }
}
